    "card.recolor.a11y": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap to change the card background color."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "轻点更换色卡背景颜色。"
